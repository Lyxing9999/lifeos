# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# Android emulator:
# API_BASE_URL=http://10.0.2.2:8080/api/v1
#
# iOS simulator:
# API_BASE_URL=http://localhost:8080/api/v1
#
# Physical device:
# API_BASE_URL=http://YOUR_MAC_LAN_IP:8080/api/v1
#
# Production later:
# API_BASE_URL=https://your-api-domain.com/api/v1
API_BASE_URL=http://localhost:8080/api/v1

# Google Maps API key.
# Not the same as OAuth Client ID.
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Google Web OAuth Client ID.
# Same value as backend GOOGLE_CLIENT_ID.
GOOGLE_SERVER_CLIENT_ID=your_web_client_id.apps.googleusercontent.com

# Optional explicit IANA timezone for auth/login payload.
# Example: Asia/Phnom_Penh
APP_TIMEZONE=Asia/Phnom_Penh
